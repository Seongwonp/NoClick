# No-Click API Settings Example
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.

# [Mandatory] AI 엔진 API 키
GEMINI_API_KEY=your_gemini_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# [Optional] Database URL (기본값은 SQLite입니다)
# PostgreSQL 예시: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./noclick.db

# App Settings
PROJECT_NAME=No-Click
VERSION=0.1.0
DEBUG=True
