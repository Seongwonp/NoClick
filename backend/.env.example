# ================================================================
# No-Click API — 환경변수 설정 파일
# ================================================================
# 사용법: 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.
#   cp .env.example .env
# ================================================================

# ----------------------------------------------------------------
# [필수] Gemini API 키
# 여러 개 입력 시 쉼표로 구분 → 자동 로테이션됨 (키 소진 방지)
# 예: GEMINI_API_KEYS=AIzaSy111,AIzaSy222,AIzaSy333
# ----------------------------------------------------------------
GEMINI_API_KEYS=your_gemini_api_key_here

# ----------------------------------------------------------------
# [선택] HuggingFace API 키
# Gemini 키 전부 소진 시 EXAONE 3.5로 자동 전환됨
# ----------------------------------------------------------------
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ----------------------------------------------------------------
# [선택] Claude API 키 (고급 추론 / 프롬프트 튜닝용)
# ----------------------------------------------------------------
CLAUDE_API_KEY=your_claude_api_key_here

# ----------------------------------------------------------------
# [선택] DB 설정
# 기본값: SQLite (로컬 파일)
# PostgreSQL 전환 시: postgresql://user:password@localhost/dbname
# ----------------------------------------------------------------
DATABASE_URL=sqlite:///./noclick.db

# ----------------------------------------------------------------
# [선택] AI 성능 튜닝 (기본값 권장, 필요 시만 수정)
# ----------------------------------------------------------------
AI_MAX_INPUT_CHARS=3000         # 입력 텍스트 최대 글자수 (초과 시 잘림)
AI_REQUEST_TIMEOUT_SECONDS=25   # AI 호출 타임아웃 (초)
AI_MAX_RETRIES=2                # 실패 시 재시도 횟수
AI_RETRY_BASE_DELAY_SECONDS=0.7 # 재시도 초기 대기 시간 (초, exponential backoff)
AI_CONCURRENCY_LIMIT=8          # 동시 AI 호출 최대 수
AI_CACHE_TTL_SECONDS=300        # 동일 입력 캐시 유지 시간 (초, 0이면 캐시 비활성화)
GEMINI_KEY_COOLDOWN_SECONDS=120 # 소진된 Gemini 키 재사용 대기 시간 (초)

# ----------------------------------------------------------------
# [선택] 보안 설정
# ----------------------------------------------------------------
# Rate Limiting: IP당 요청 제한 (기본: 분당 10회)
RATE_LIMIT=10/minute

# CORS 허용 도메인 (쉼표로 구분)
# 배포 시 실제 도메인으로 변경 필수!
# 예: ALLOWED_ORIGINS=https://noclick.com,https://www.noclick.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000

# ----------------------------------------------------------------
# [선택] 앱 정보
# ----------------------------------------------------------------
PROJECT_NAME=No-Click
VERSION=0.1.0
